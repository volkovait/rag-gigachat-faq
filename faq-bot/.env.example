# Скопируйте в .env и подставьте ключ из кабинета GigaChat (Basic).
GIGACHAT_CREDENTIALS=

GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_API_BASE=https://gigachat.devices.sberbank.ru/api
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth

# Для корпоративных сетей часто требуется false (как в langchain_gigachat).
GIGACHAT_VERIFY_SSL=false

GIGACHAT_EMBEDDINGS_MODEL=Embeddings
GIGACHAT_CHAT_MODEL=GigaChat

FAQ_BOT_HOST=127.0.0.1
FAQ_BOT_PORT=8765
